# gold-bot environment template.
# Copy to .env (which is gitignored) and fill in as needed.
# NEVER commit real secrets. Broker / live-trading credentials must NOT live here
# if this repo is public — they belong only in a separate always-on execution host.

# ---- Account rules (override the defaults in config/settings.py) ----
GOLDBOT_ACCOUNT_SIZE=50000
GOLDBOT_TRAILING_DRAWDOWN=2500
GOLDBOT_DAILY_LOSS_LIMIT=1250
GOLDBOT_PROFIT_TARGET=3000
GOLDBOT_MAX_CONTRACTS=10

# ---- Data source (optional paid intraday adapter) ----
# Only data API keys belong here. Used by GitHub Actions via repo Secrets.
DATABENTO_API_KEY=
TRADOVATE_DATA_TOKEN=

# ---- Misc ----
GOLDBOT_DATA_CACHE_DIR=.cache
